{$DOMAIN:localhost} {
    # API routes
    handle /api/* {
        reverse_proxy api:8080
    }

    # SSR frontend
    handle {
        reverse_proxy frontend:4321
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    log {
        output stdout
    }
}

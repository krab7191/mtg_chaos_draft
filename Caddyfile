{$DOMAIN:localhost} {
    # API routes
    handle /api/* {
        reverse_proxy api:8080 {
            lb_try_duration 30s
            lb_try_interval 250ms
        }
    }

    # SSR frontend
    handle {
        reverse_proxy frontend:4321 {
            lb_try_duration 30s
            lb_try_interval 250ms
        }
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://lh3.googleusercontent.com; connect-src 'self'; font-src 'self'; frame-ancestors 'none'"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
    }

    log {
        output stdout
    }
}

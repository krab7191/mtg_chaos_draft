{$DOMAIN:localhost} {
    # API routes
    handle /api/* {
        reverse_proxy api:8080
    }

    # Static mode: serve files from /srv
    handle {
        root * /srv
        file_server
        try_files {path} /index.html
    }

    # SSR mode: uncomment below, comment out static block above
    # handle {
    #     reverse_proxy frontend:4321
    # }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    log {
        output stdout
    }
}

---
import '../styles/global.scss';

interface Props {
  title: string;
  user?: { name: string; email: string; role: string; picture?: string } | null;
}

const { title, user } = Astro.props;
const version = import.meta.env.PUBLIC_APP_VERSION;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — MTG Chaos Draft</title>
  </head>
  <body>
    <nav class="nav">
      <a href="/" class="nav__brand">Chaos Draft</a>

      {user && (
        <button class="nav__toggle" id="nav-toggle" aria-label="Open menu" aria-expanded="false">
          {user.picture
            ? <img class="nav__avatar" src={user.picture} alt="" referrerpolicy="no-referrer" />
            : <span class="nav__avatar nav__avatar--initial">{user.name.charAt(0).toUpperCase()}</span>
          }
          <svg class="nav__burger" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <rect y="3"  width="18" height="2" rx="1" fill="currentColor"/>
            <rect y="8"  width="18" height="2" rx="1" fill="currentColor"/>
            <rect y="13" width="18" height="2" rx="1" fill="currentColor"/>
          </svg>
        </button>
      )}
    </nav>

    {user && (
      <>
        <div class="nav-overlay" id="nav-overlay"></div>
        <div class="nav-menu" id="nav-menu" aria-hidden="true">
          <a href="/select" class="nav-menu__item">Pick a Pack</a>
          {['admin', 'viewer'].includes(user.role) && <a href="/admin/collection" class="nav-menu__item">Manage Collection</a>}
          {['admin', 'viewer'].includes(user.role) && <a href="/admin/weights" class="nav-menu__item">Weights</a>}
          <div class="nav-menu__footer">
            <div class="nav-menu__footer-row">
              <span class="nav-menu__user">{user.name}</span>
              <form method="POST" action="/api/auth/logout" style="display:inline">
                <button type="submit" class="nav-menu__logout">Sign out</button>
              </form>
            </div>
            <span class="nav-menu__version">{version}</span>
          </div>
        </div>
      </>
    )}

    <main class="main">
      <slot />
    </main>

    <div id="app-toast" class="app-toast" hidden>
      <span class="app-toast__msg"></span>
      <div class="app-toast__actions">
        <button class="app-toast__confirm">Remove</button>
        <button class="app-toast__cancel">Cancel</button>
      </div>
      <button class="app-toast__close" aria-label="Dismiss" hidden>✕</button>
    </div>
  </body>
</html>

<style lang="scss">
  /* ── Nav bar ─────────────────────────────────────────────── */
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 1rem;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 200;

    &__brand {
      font-size: 1rem;
      font-weight: 700;
      color: var(--color-text);
      text-decoration: none;
      &:hover { text-decoration: none; }
    }

    &__toggle {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      background: none;
      border: 1px solid var(--color-border);
      border-radius: 999px;
      padding: 0.2rem 0.6rem 0.2rem 0.25rem;
      color: var(--color-text-muted);
      cursor: pointer;
      transition: border-color 0.15s;

      &:hover,
      &[aria-expanded="true"] {
        border-color: var(--color-accent);
        color: var(--color-text);
      }
    }

    &__avatar {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      object-fit: cover;
      display: block;

      &--initial {
        background: var(--color-accent);
        color: white;
        font-size: 0.8rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
    }

    &__burger {
      display: block;
      flex-shrink: 0;
    }
  }

  /* ── Dropdown menu ───────────────────────────────────────── */
  .nav-menu {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(280px, 85vw);
    background: var(--color-surface);
    border-left: 1px solid var(--color-border);
    box-shadow: -8px 0 24px rgba(0, 0, 0, 0.4);
    z-index: 300;
    display: flex;
    flex-direction: column;
    padding-top: 3.5rem; /* clear the sticky nav */
    transform: translateX(100%);
    transition: transform 0.25s ease;

    &.open {
      transform: translateX(0);
    }

    &__item {
      display: block;
      padding: 0.9rem 1.25rem;
      color: var(--color-text-muted);
      font-size: 0.95rem;
      border-left: 3px solid transparent;
      transition: color 0.1s, border-color 0.1s, background 0.1s;

      &:hover {
        color: var(--color-text);
        border-left-color: var(--color-accent);
        background: var(--color-bg);
        text-decoration: none;
      }
    }

    &__footer {
      margin-top: auto;
      padding: 1rem 1.25rem;
      border-top: 1px solid var(--color-border);
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    &__footer-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
    }

    &__user {
      color: var(--color-text-muted);
      font-size: 0.82rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    &__version {
      font-size: 0.7rem;
      color: var(--color-text-muted);
      opacity: 0.5;
    }

    &__logout {
      background: none;
      border: 1px solid var(--color-border);
      color: var(--color-text-muted);
      padding: 0.2rem 0.55rem;
      border-radius: var(--radius);
      font-size: 0.82rem;
      white-space: nowrap;
      flex-shrink: 0;
      &:hover { border-color: var(--color-accent); color: var(--color-accent); }
    }
  }

  /* Overlay (click outside to close) */
  .nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 250;
    background: rgba(0, 0, 0, 0.4);

    &.open { display: block; }
  }

  /* ── Delete toast ────────────────────────────────────────── */
  .app-toast {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.6rem 0.75rem 0.6rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.88rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    z-index: 500;
    max-width: min(420px, calc(100vw - 2rem));
    animation: toast-in 0.18s ease;

    &[hidden] { display: none; }

    &__msg {
      color: var(--color-text);
      flex: 1;
      min-width: 0;
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
    }

    &__actions {
      display: flex;
      gap: 0.4rem;
      flex-shrink: 0;
    }

    &__confirm, &__cancel {
      background: none;
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      padding: 0.18rem 0.55rem;
      font-size: 0.82rem;
      cursor: pointer;
      white-space: nowrap;
    }

    &__confirm {
      color: var(--color-danger);
      &:hover { border-color: var(--color-danger); }
    }

    &__cancel {
      color: var(--color-text-muted);
      &:hover { border-color: var(--color-text-muted); color: var(--color-text); }
    }

    &__close {
      background: none;
      border: none;
      color: var(--color-text-muted);
      font-size: 0.75rem;
      padding: 0.1rem 0.3rem;
      flex-shrink: 0;
      &:hover { color: var(--color-text); }
      &[hidden] { display: none; }
    }

    &--error  { border-color: var(--color-danger); }
    &--success { border-color: var(--color-success); }
  }

  @keyframes toast-in {
    from { opacity: 0; transform: translateX(-50%) translateY(6px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  /* ── Main content ────────────────────────────────────────── */
  .main {
    padding: 1.25rem 1rem;
    max-width: 768px;
    margin: 0 auto;

    @media (min-width: 500px) {
      padding: 2rem 1.5rem;
    }
  }
</style>

<script>
  // ── Toast ──────────────────────────────────────────────────────
  declare global {
    interface Window {
      deleteToast(msg: string, onConfirm: () => void, onCancel: () => void): void;
      showToast(msg: string, type?: 'error' | 'success' | 'info'): void;
    }
  }

  const appToast   = document.getElementById('app-toast')!;
  const toastMsg   = appToast.querySelector<HTMLElement>('.app-toast__msg')!;
  const toastActions = appToast.querySelector<HTMLElement>('.app-toast__actions')!;
  const toastClose = appToast.querySelector<HTMLButtonElement>('.app-toast__close')!;
  let toastConfirm = appToast.querySelector<HTMLButtonElement>('.app-toast__confirm')!;
  let toastCancel  = appToast.querySelector<HTMLButtonElement>('.app-toast__cancel')!;
  let notifTimer: ReturnType<typeof setTimeout> | null = null;

  function dismissToast() {
    appToast.hidden = true;
    appToast.classList.remove('app-toast--error', 'app-toast--success');
    if (notifTimer) { clearTimeout(notifTimer); notifTimer = null; }
  }

  window.deleteToast = (msg, onConfirm, onCancel) => {
    dismissToast();
    toastMsg.textContent = msg;
    toastActions.hidden = false;
    toastClose.hidden = true;
    appToast.hidden = false;

    const newConfirm = toastConfirm.cloneNode(true) as HTMLButtonElement;
    const newCancel  = toastCancel.cloneNode(true)  as HTMLButtonElement;
    toastConfirm.replaceWith(newConfirm); toastConfirm = newConfirm;
    toastCancel.replaceWith(newCancel);   toastCancel  = newCancel;

    toastConfirm.addEventListener('click', () => { dismissToast(); onConfirm(); });
    toastCancel.addEventListener ('click', () => { dismissToast(); onCancel();  });
  };

  window.showToast = (msg, type = 'info') => {
    dismissToast();
    toastMsg.textContent = msg;
    toastActions.hidden = true;
    toastClose.hidden = false;
    if (type !== 'info') appToast.classList.add(`app-toast--${type}`);
    appToast.hidden = false;
    toastClose.onclick = dismissToast;
    notifTimer = setTimeout(dismissToast, 4000);
  };

  // ── Nav ───────────────────────────────────────────────────────
  const toggle  = document.getElementById('nav-toggle') as HTMLButtonElement;
  const menu    = document.getElementById('nav-menu') as HTMLElement;
  const overlay = document.getElementById('nav-overlay') as HTMLElement;

  function openMenu() {
    menu.classList.add('open');
    overlay.classList.add('open');
    menu.setAttribute('aria-hidden', 'false');
    toggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu.classList.remove('open');
    overlay.classList.remove('open');
    menu.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle.addEventListener('click', () => {
    menu.classList.contains('open') ? closeMenu() : openMenu();
  });

  overlay.addEventListener('click', closeMenu);

  // Close on nav link click
  menu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>

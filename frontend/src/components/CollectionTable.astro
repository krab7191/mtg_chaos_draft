---
interface Pack {
  id: number;
  scryfallSetCode: string;
  name: string;
  setName: string;
  productType: string;
  quantity: number;
  weight: number;
  notes: string;
}

interface Props {
  packs: Pack[];
}

const { packs } = Astro.props;
---

<div class="collection" id="collection-table">
  {packs.length === 0 ? (
    <p class="collection__empty">No packs yet — search above to add some.</p>
  ) : (
    <table class="table">
      <thead>
        <tr>
          <th>Set</th>
          <th>Type</th>
          <th>Qty</th>
          <th>Weight</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {packs.map((pack) => (
          <tr data-id={pack.id}>
            <td class="col-set">{pack.setName}</td>
            <td class="col-type">{pack.productType}</td>
            <td class="col-qty">
              <input type="number" class="inline-edit" value={pack.quantity}
                min="0" data-field="quantity" data-id={pack.id} />
            </td>
            <td class="col-weight">
              <input type="number" class="inline-edit" value={pack.weight}
                step="0.1" min="0" data-field="weight" data-id={pack.id} />
            </td>
            <td class="col-actions">
              <button class="btn-delete" data-id={pack.id} title="Remove">✕</button>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
</div>

<style lang="scss">
  .collection {
    &__empty {
      color: var(--color-text-muted);
      padding: 3rem 0;
      text-align: center;
    }
  }

  .table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;

    th {
      text-align: left;
      padding: 0.6rem 0.75rem;
      color: var(--color-text-muted);
      font-weight: 600;
      border-bottom: 2px solid var(--color-border);
      white-space: nowrap;
    }

    td {
      padding: 0.55rem 0.75rem;
      border-bottom: 1px solid var(--color-border);
      vertical-align: middle;
    }

    tr:hover td { background: var(--color-surface); }

    .col-set { font-weight: 500; }
    .col-type { color: var(--color-text-muted); font-size: 0.85rem; }
  }

  .inline-edit {
    width: 5rem;
    padding: 0.25rem 0.4rem;
    border-radius: var(--radius);
    border: 1px solid transparent;
    background: transparent;
    color: var(--color-text);
    text-align: right;
    font-size: 0.9rem;

    &:hover { border-color: var(--color-border); }
    &:focus { border-color: var(--color-accent); background: var(--color-surface); outline: none; }
  }

  .btn-delete {
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    border-radius: var(--radius);
    padding: 0.2rem 0.5rem;
    font-size: 0.8rem;
    &:hover { border-color: var(--color-danger); color: var(--color-danger); }
  }
</style>

<script>
  document.querySelectorAll<HTMLInputElement>('.inline-edit').forEach((input) => {
    const save = async () => {
      const id = input.dataset.id;
      const field = input.dataset.field!;
      const value = parseFloat(input.value);
      if (isNaN(value)) return;
      await fetch(`/api/collection/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ [field]: value }),
      });
    };
    input.addEventListener('blur', save);
    input.addEventListener('keydown', (e) => { if (e.key === 'Enter') input.blur(); });
  });

  document.querySelectorAll<HTMLButtonElement>('.btn-delete').forEach((btn) => {
    btn.addEventListener('click', async () => {
      if (!confirm('Remove this pack from the collection?')) return;
      const res = await fetch(`/api/collection/${btn.dataset.id}`, { method: 'DELETE' });
      if (res.ok) btn.closest('tr')?.remove();
    });
  });

  document.addEventListener('collection-updated', () => window.location.reload());
</script>

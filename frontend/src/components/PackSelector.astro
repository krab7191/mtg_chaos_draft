---
interface Pack {
  id: number;
  name: string;
  setName: string;
  productType: string;
  quantity: number;
  weight: number;
  marketPrice?: number | null;
}

interface Settings {
  priceSensitivity: number;
  scarcitySensitivity: number;
}

interface Props {
  packs: Pack[];
  settings: Settings;
}

const { packs, settings } = Astro.props;
---

<div class="selector">
  {packs.length === 0 ? (
    <p class="selector__empty">The collection is empty. Ask your admin to add some packs!</p>
  ) : (
    <>
      <div class="selector__controls"
        data-price-sensitivity={settings.priceSensitivity}
        data-scarcity-sensitivity={settings.scarcitySensitivity}
      >
        <button id="select-all" class="btn btn--secondary">Select all</button>
        <button id="deselect-all" class="btn btn--secondary">Deselect all</button>
        <span class="selector__count" id="selected-count">0 selected</span>
      </div>

      <ul class="pack-list" id="pack-list">
        {packs.map((pack) => (
          <li class="pack-item">
            <label class="pack-item__label">
              <input type="checkbox" class="pack-checkbox" value={pack.id} checked
                data-weight={pack.weight}
                data-qty={pack.quantity}
                data-price={pack.marketPrice ?? ''}
              />
              <span class="pack-item__name">{pack.name}</span>
              <span class="pack-item__meta">{pack.setName}</span>
              <span class="pack-item__odds">—</span>
            </label>
          </li>
        ))}
      </ul>

      <button id="pick-btn" class="btn btn--primary btn--large">🎲 Pick a Pack</button>

      <div class="result" id="result" hidden>
        <div class="result__card">
          <p class="result__label">You're drafting with:</p>
          <h2 class="result__name" id="result-name"></h2>
          <p class="result__set" id="result-set"></p>
          <div class="result__links" id="result-links"></div>
          <button id="pick-again" class="btn btn--secondary" style="margin-top:1rem">Pick again</button>
        </div>
      </div>
    </>
  )}
</div>

<style lang="scss">
  .selector {
    &__controls {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 0.9rem;
    }

    &__count {
      color: var(--color-text-muted);
      font-size: 0.82rem;
      margin-left: auto;
    }

    &__empty {
      color: var(--color-text-muted);
      text-align: center;
      padding: 3rem 0;
    }
  }

  .pack-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.25rem;

    @media (min-width: 480px) {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 0.5rem;
    }
  }

  .pack-item {
    &__label {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.65rem 0.8rem;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      cursor: pointer;
      transition: border-color 0.1s;
      min-height: 2.8rem; /* bigger tap target */

      &:hover { border-color: var(--color-accent); }
    }

    &__name {
      font-weight: 500;
      font-size: 0.88rem;
      flex: 1;
      line-height: 1.3;
    }

    &__meta {
      color: var(--color-text-muted);
      font-size: 0.75rem;
      white-space: nowrap;
    }

    &__odds {
      color: var(--color-accent);
      font-size: 0.78rem;
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
    }

    input[type="checkbox"] { accent-color: var(--color-accent); flex-shrink: 0; }
  }

  .btn {
    border: none;
    border-radius: var(--radius);
    padding: 0.5rem 1rem;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.15s;

    &:disabled { opacity: 0.5; cursor: not-allowed; }
    &:hover:not(:disabled) { opacity: 0.85; }

    &--primary { background: var(--color-accent); color: white; }
    &--secondary {
      background: var(--color-surface);
      color: var(--color-text);
      border: 1px solid var(--color-border);
    }
    &--large {
      width: 100%;
      padding: 0.85rem 1.5rem;
      font-size: 1rem;

      @media (min-width: 480px) {
        width: auto;
        padding: 0.75rem 2rem;
        font-size: 1.1rem;
      }
    }
  }

  .result {
    margin-top: 2rem;

    &__card {
      background: var(--color-surface);
      border: 1px solid var(--color-accent);
      border-radius: 12px;
      padding: 2rem;
      text-align: center;
      animation: pop 0.3s ease;
    }

    &__label {
      color: var(--color-text-muted);
      margin-bottom: 0.5rem;
    }

    &__name {
      font-size: 1.8rem;
      margin-bottom: 0.25rem;
    }

    &__set {
      color: var(--color-text-muted);
      margin-bottom: 1rem;
    }

    &__links {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem;

      a {
        background: var(--color-surface-2);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        padding: 0.3rem 0.8rem;
        font-size: 0.85rem;
        color: var(--color-text);
        &:hover { border-color: var(--color-accent); text-decoration: none; }
      }
    }
  }

  @keyframes pop {
    from { transform: scale(0.92); opacity: 0; }
    to   { transform: scale(1);    opacity: 1; }
  }
</style>

<script>
  const pickBtn = document.getElementById('pick-btn') as HTMLButtonElement;
  const resultDiv = document.getElementById('result') as HTMLDivElement;
  const resultName = document.getElementById('result-name') as HTMLElement;
  const resultSet = document.getElementById('result-set') as HTMLElement;
  const resultLinks = document.getElementById('result-links') as HTMLElement;
  const pickAgain = document.getElementById('pick-again') as HTMLButtonElement;
  const countEl = document.getElementById('selected-count') as HTMLElement;
  const checkboxes = () => document.querySelectorAll<HTMLInputElement>('.pack-checkbox');

  const controls = document.querySelector<HTMLElement>('.selector__controls')!;
  const priceSens    = parseFloat(controls.dataset.priceSensitivity    ?? '0');
  const scarcitySens = parseFloat(controls.dataset.scarcitySensitivity ?? '0');

  function effectiveWeight(cb: HTMLInputElement, checkedBoxes: HTMLInputElement[]): number {
    const weight = parseFloat(cb.dataset.weight ?? '1') || 1;
    const qty    = parseInt(cb.dataset.qty     ?? '1') || 1;
    const price  = cb.dataset.price ? parseFloat(cb.dataset.price) : null;

    const prices = checkedBoxes
      .map(c => c.dataset.price ? parseFloat(c.dataset.price) : null)
      .filter((p): p is number => p !== null && p > 0);
    const minPrice = prices.length ? Math.min(...prices) : 0;
    const maxQty   = Math.max(...checkedBoxes.map(c => parseInt(c.dataset.qty ?? '1') || 1), 1);

    let priceFactor = 1;
    if (priceSens > 0 && price && price > 0 && minPrice > 0) {
      priceFactor = (1 - priceSens) + priceSens * (minPrice / price);
    }
    const qtyFactor = (1 - scarcitySens) + scarcitySens * (qty / maxQty);
    return weight * priceFactor * qtyFactor;
  }

  function updateCount() {
    const all     = [...checkboxes()];
    const checked = all.filter(c => c.checked);
    countEl.textContent = `${checked.length} selected`;
    pickBtn.disabled = checked.length === 0;

    // Recompute effective odds for checked items
    const total = checked.reduce((s, c) => s + effectiveWeight(c, checked), 0);
    all.forEach(cb => {
      const oddsEl = cb.closest('.pack-item__label')?.querySelector('.pack-item__odds');
      if (!oddsEl) return;
      if (!cb.checked || total === 0) { oddsEl.textContent = '—'; return; }
      const pct = (effectiveWeight(cb, checked) / total) * 100;
      oddsEl.textContent = `${pct.toFixed(1)}%`;
    });
  }

  checkboxes().forEach(c => c.addEventListener('change', updateCount));
  document.getElementById('select-all')?.addEventListener('click', () => { checkboxes().forEach(c => c.checked = true); updateCount(); });
  document.getElementById('deselect-all')?.addEventListener('click', () => { checkboxes().forEach(c => c.checked = false); updateCount(); });
  updateCount();

  pickBtn.addEventListener('click', async () => {
    const ids = [...checkboxes()].filter(c => c.checked).map(c => parseInt(c.value));
    if (ids.length === 0) return;

    pickBtn.disabled = true;
    pickBtn.textContent = '🎲 Picking...';

    const res = await fetch('/api/select', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ packIds: ids }),
    });

    pickBtn.disabled = false;
    pickBtn.textContent = '🎲 Pick a Pack';

    if (!res.ok) return;
    const { selectedPack } = await res.json();

    resultName.textContent = selectedPack.name;
    resultSet.textContent = `${selectedPack.setName}${selectedPack.productType ? ' · ' + selectedPack.productType : ''}`;

    // Fetch live links
    resultLinks.innerHTML = '';
    try {
      const priceRes = await fetch(`/api/price/${selectedPack.mtgstocksId}`);
      if (priceRes.ok) {
        const data = await priceRes.json();
        const urls = data.purchase_urls ?? {};
        if (urls.tcgplayer) resultLinks.innerHTML += `<a href="${urls.tcgplayer}" target="_blank" rel="noopener">TCGPlayer</a>`;
        if (urls.cardkingdom) resultLinks.innerHTML += `<a href="${urls.cardkingdom}" target="_blank" rel="noopener">Card Kingdom</a>`;
        if (urls.cardmarket) resultLinks.innerHTML += `<a href="${urls.cardmarket}" target="_blank" rel="noopener">Cardmarket</a>`;
      }
    } catch { /* links optional */ }

    resultDiv.hidden = false;
    resultDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });

  pickAgain?.addEventListener('click', () => { resultDiv.hidden = true; });
</script>

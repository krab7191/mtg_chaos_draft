---
interface Pack {
  id: number;
  name: string;
  setName: string;
  productType: string;
  quantity: number;
  marketPrice?: number | null;
}

interface Props {
  packs: Pack[];
}

const { packs } = Astro.props;
---

<div class="selector">
  {packs.length === 0 ? (
    <p class="selector__empty">The collection is empty. Ask your admin to add some packs!</p>
  ) : (
    <>
      <div class="selector__controls">
        <button id="select-all" class="btn btn--secondary">Select all</button>
        <button id="deselect-all" class="btn btn--secondary">Deselect all</button>
        <span class="selector__count" id="selected-count">0 selected</span>
      </div>

      <ul class="pack-list" id="pack-list">
        {packs.map((pack) => (
          <li class="pack-item">
            <label class="pack-item__label">
              <input type="checkbox" class="pack-checkbox" value={pack.id} checked
                data-price={pack.marketPrice ?? ''}
                data-qty={pack.quantity}
                data-name={pack.name}
                data-set={pack.setName}
                data-product-type={pack.productType}
              />
              <span class="pack-item__info">
                <span class="pack-item__name">{pack.setName}</span>
                <span class="pack-item__meta">{pack.productType}</span>
              </span>
              <span class="pack-item__price">
                {pack.marketPrice != null ? `$${pack.marketPrice.toFixed(2)}` : '—'}
              </span>
              <span class="pack-item__odds">—</span>
            </label>
          </li>
        ))}
      </ul>

      <div class="pick-row">
        <button id="pick-btn" class="btn btn--primary btn--large">🎲 Pick a Pack</button>
        <label class="history-toggle">
          <input type="checkbox" id="history-on" />
          Record draft
        </label>
      </div>

      <div class="toast" id="result" hidden>
        <span class="toast__text" id="result-text"></span>
      </div>

      <div class="history" id="history-section" hidden>
        <div class="history__header">
          <span class="history__title">Draft history</span>
          <button class="history__clear" id="history-clear">Clear</button>
        </div>
        <ol class="history__list" id="history-list"></ol>
      </div>
    </>
  )}
</div>

<style lang="scss">
  .selector {
    &__controls {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 0.9rem;
    }

    &__count {
      color: var(--color-text-muted);
      font-size: 0.82rem;
      margin-left: auto;
    }

    &__empty {
      color: var(--color-text-muted);
      text-align: center;
      padding: 3rem 0;
    }
  }

  .pack-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.25rem;

    @media (min-width: 480px) {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 0.5rem;
    }
  }

  .pack-item {
    min-width: 0;

    &__label {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.65rem 0.8rem;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      cursor: pointer;
      transition: border-color 0.1s;
      min-height: 2.8rem;
      min-width: 0;
      overflow: hidden;

      &:hover { border-color: var(--color-accent); }
    }

    &__info {
      flex: 1;
      min-width: 0;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
    }

    &__name {
      font-weight: 500;
      font-size: 0.88rem;
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
    }

    &__meta {
      color: var(--color-text-muted);
      font-size: 0.73rem;
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
    }

    &__price {
      color: var(--color-text-muted);
      font-size: 0.75rem;
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
      flex-shrink: 0;
    }

    &__odds {
      color: var(--color-accent);
      font-size: 0.78rem;
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
      flex-shrink: 0;
    }

    input[type="checkbox"] { accent-color: var(--color-accent); flex-shrink: 0; }
  }

  .pick-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .history-toggle {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.88rem;
    color: var(--color-text-muted);
    cursor: pointer;
    user-select: none;

    input { accent-color: var(--color-accent); }
  }

  .history {
    margin-top: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;

    &__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.55rem 0.85rem;
      background: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
    }

    &__title {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--color-text-muted);
    }

    &__clear {
      background: none;
      border: none;
      font-size: 0.78rem;
      color: var(--color-text-muted);
      cursor: pointer;
      padding: 0;
      &:hover { color: var(--color-danger); }
    }

    &__list {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    &__item {
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
      padding: 0.5rem 0.85rem;
      border-bottom: 1px solid var(--color-border);
      font-size: 0.88rem;

      &:last-child { border-bottom: none; }
    }

    &__num {
      color: var(--color-text-muted);
      font-size: 0.75rem;
      font-variant-numeric: tabular-nums;
      min-width: 1.2rem;
    }

    &__pack-info {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
    }

    &__pack-name {
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
    }

    &__pack-set {
      color: var(--color-text-muted);
      font-size: 0.75rem;
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
    }

    &__pack-price {
      color: var(--color-text-muted);
      font-size: 0.78rem;
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
    }
  }

  .btn {
    border: none;
    border-radius: var(--radius);
    padding: 0.5rem 1rem;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.15s;

    &:disabled { opacity: 0.5; cursor: not-allowed; }
    &:hover:not(:disabled) { opacity: 0.85; }

    &--primary { background: var(--color-accent); color: white; }
    &--secondary {
      background: var(--color-surface);
      color: var(--color-text);
      border: 1px solid var(--color-border);
    }
    &--large {
      padding: 0.85rem 1.5rem;
      font-size: 1rem;

      @media (min-width: 480px) {
        padding: 0.75rem 2rem;
        font-size: 1.1rem;
      }
    }
  }

  .toast {
    position: fixed;
    top: 3.75rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-surface);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius);
    padding: 0.85rem 1.75rem;
    font-size: 1.05rem;
    font-weight: 500;
    white-space: nowrap;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.35);
    z-index: 50;
    animation: slideDown 0.2s ease;

    &__text {
      color: var(--color-text);
    }
  }

  @keyframes slideDown {
    from { transform: translateX(-50%) translateY(-0.75rem); opacity: 0; }
    to   { transform: translateX(-50%) translateY(0);        opacity: 1; }
  }
</style>

<script>
  const HISTORY_KEY = 'draft-history';
  const MAX_HISTORY = 12;

  const pickBtn    = document.getElementById('pick-btn') as HTMLButtonElement;
  const resultDiv  = document.getElementById('result') as HTMLDivElement;
  const resultText = document.getElementById('result-text') as HTMLElement;
  const countEl    = document.getElementById('selected-count') as HTMLElement;
  const historyToggle   = document.getElementById('history-on') as HTMLInputElement;
  const historySection  = document.getElementById('history-section') as HTMLElement;
  const historyList     = document.getElementById('history-list') as HTMLElement;
  const historyClear    = document.getElementById('history-clear') as HTMLButtonElement;
  const checkboxes = () => document.querySelectorAll<HTMLInputElement>('.pack-checkbox');

  // ── History ──────────────────────────────────────────────────
  interface HistoryEntry { name: string; setName: string; price: string; }

  function loadHistory(): HistoryEntry[] {
    try { return JSON.parse(localStorage.getItem(HISTORY_KEY) ?? '[]'); } catch { return []; }
  }

  function saveHistory(entries: HistoryEntry[]) {
    localStorage.setItem(HISTORY_KEY, JSON.stringify(entries));
  }

  function renderHistory() {
    const entries = loadHistory();
    historySection.hidden = !historyToggle.checked || entries.length === 0;
    historyList.innerHTML = entries.map((e, i) => `
      <li class="history__item">
        <span class="history__num">${i + 1}.</span>
        <span class="history__pack-info">
          <span class="history__pack-name">${e.name}</span>
          <span class="history__pack-set">${e.setName}</span>
        </span>
        <span class="history__pack-price">${e.price}</span>
      </li>`).join('');
  }

  function addToHistory(pack: { name: string; setName: string; marketPrice?: number | null }) {
    if (!historyToggle.checked) return;
    const entries = loadHistory();
    if (entries.length >= MAX_HISTORY) return;
    entries.push({
      name:    pack.name,
      setName: pack.setName,
      price:   pack.marketPrice != null ? `$${pack.marketPrice.toFixed(2)}` : '—',
    });
    saveHistory(entries);
    renderHistory();
    if (entries.length >= MAX_HISTORY) historyToggle.checked = false;
  }

  historyToggle.addEventListener('change', renderHistory);

  historyClear.addEventListener('click', () => {
    saveHistory([]);
    renderHistory();
  });

  // Restore toggle state from localStorage
  historyToggle.checked = loadHistory().length > 0 && loadHistory().length < MAX_HISTORY;
  renderHistory();

  // ── Odds ─────────────────────────────────────────────────────
  function effectiveWeight(cb: HTMLInputElement, checkedBoxes: HTMLInputElement[]): number {
    const qty = parseInt(cb.dataset.qty ?? '0');
    if (qty === 0) return 0;

    const prices = checkedBoxes
      .map(c => c.dataset.price ? parseFloat(c.dataset.price) : null)
      .filter((p): p is number => p !== null && p > 0);
    const avgPrice = prices.length ? prices.reduce((a, b) => a + b, 0) / prices.length : 1;

    const pw = checkedBoxes.map(c => {
      const p = c.dataset.price ? parseFloat(c.dataset.price) : null;
      return 1 / ((p && p > 0) ? p : avgPrice);
    });
    const sw = checkedBoxes.map(c => {
      const q = parseInt(c.dataset.qty ?? '0');
      return q > 0 ? 1 / q : 0;
    });

    const priceTotal    = pw.reduce((a, b) => a + b, 0);
    const scarcityTotal = sw.reduce((a, b) => a + b, 0);

    const idx = checkedBoxes.indexOf(cb);
    const priceOdds    = priceTotal    > 0 ? pw[idx] / priceTotal    : 0;
    const scarcityOdds = scarcityTotal > 0 ? sw[idx] / scarcityTotal : 0;
    return Math.min(priceOdds, scarcityOdds);
  }

  function updateCount() {
    const all     = [...checkboxes()];
    const checked = all.filter(c => c.checked);
    countEl.textContent = `${checked.length} selected`;
    pickBtn.disabled = checked.length === 0;

    const total = checked.reduce((s, c) => s + effectiveWeight(c, checked), 0);
    all.forEach(cb => {
      const oddsEl = cb.closest('.pack-item__label')?.querySelector('.pack-item__odds');
      if (!oddsEl) return;
      if (!cb.checked || total === 0) { oddsEl.textContent = '—'; return; }
      const pct = (effectiveWeight(cb, checked) / total) * 100;
      oddsEl.textContent = `${pct.toFixed(1)}%`;
    });
  }

  checkboxes().forEach(c => c.addEventListener('change', updateCount));
  document.getElementById('select-all')?.addEventListener('click', () => { checkboxes().forEach(c => c.checked = true); updateCount(); });
  document.getElementById('deselect-all')?.addEventListener('click', () => { checkboxes().forEach(c => c.checked = false); updateCount(); });
  updateCount();

  // ── Pick ─────────────────────────────────────────────────────
  pickBtn.addEventListener('click', async () => {
    const ids = [...checkboxes()].filter(c => c.checked).map(c => parseInt(c.value));
    if (ids.length === 0) return;

    pickBtn.disabled = true;
    pickBtn.textContent = '🎲 Picking...';

    const res = await fetch('/api/select', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ packIds: ids }),
    });

    pickBtn.disabled = false;
    pickBtn.textContent = '🎲 Pick a Pack';

    if (!res.ok) return;
    const { selectedPack } = await res.json();

    const type = selectedPack.productType ? ` · ${selectedPack.productType}` : '';
    resultText.textContent = `${selectedPack.setName}${type}`;

    addToHistory(selectedPack);

    // Re-trigger animation on repeat picks
    resultDiv.hidden = true;
    requestAnimationFrame(() => { resultDiv.hidden = false; });
    scheduleToastDismiss();
  });

  let toastTimer: ReturnType<typeof setTimeout> | null = null;

  function dismissToast() {
    resultDiv.hidden = true;
    if (toastTimer) { clearTimeout(toastTimer); toastTimer = null; }
  }

  function scheduleToastDismiss() {
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(dismissToast, 3000);
  }

  resultDiv.addEventListener('click', dismissToast);

</script>

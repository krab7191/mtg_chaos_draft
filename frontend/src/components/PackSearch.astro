---
// Client-side search component — talks to /api/search (MTGStocks-backed)
---

<div class="search" id="pack-search">
  <input
    type="text"
    id="search-input"
    class="search__input"
    placeholder="Search sets (Zendikar, Dominaria...)"
    autocomplete="off"
  />
  <div class="search__results" id="search-results" hidden></div>
</div>

<style lang="scss">
  .search {
    position: relative;
    margin-bottom: 2rem;

    &__input {
      width: 100%;
      padding: 0.7rem 1rem;
      font-size: 1rem;
      border-radius: var(--radius);
      border: 1px solid var(--color-border);
      background: var(--color-surface);
      color: var(--color-text);

      &:focus { outline: 2px solid var(--color-accent); }
    }

    &__results {
      position: absolute;
      top: calc(100% + 4px);
      left: 0;
      right: 0;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      z-index: 100;
      max-height: 420px;
      overflow-y: auto;
      box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    }

    &__empty {
      padding: 1rem;
      color: var(--color-text-muted);
      font-size: 0.9rem;
      text-align: center;
    }
  }
</style>

<style lang="scss" is:global>
  .set-group {
    border-bottom: 1px solid var(--color-border);

    &:last-child { border-bottom: none; }

    &__header {
      padding: 0.45rem 0.75rem 0.3rem;
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
    }

    &__name {
      font-weight: 600;
      font-size: 0.88rem;
    }

    &__year {
      color: var(--color-text-muted);
      font-size: 0.75rem;
    }

    &__pack {
      padding: 0.3rem 0.75rem 0.3rem 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;

      &:last-child { padding-bottom: 0.45rem; }
      &:hover { background: var(--color-surface-2); }
    }

    &__type {
      flex: 1;
      color: var(--color-text-muted);
      font-size: 0.82rem;
    }

    &__price {
      color: var(--color-text-muted);
      font-size: 0.75rem;
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
    }
  }

  .set-result {
    &__add-group {
      display: flex;
      align-items: center;
      gap: 0;
      flex-shrink: 0;
    }

    &__qty {
      width: 2.8rem;
      padding: 0.2rem 0.25rem;
      font-size: 0.73rem;
      text-align: center;
      border: 1px solid var(--color-border);
      border-right: none;
      border-radius: var(--radius) 0 0 var(--radius);
      background: var(--color-surface);
      color: var(--color-text);
      &:focus { outline: none; border-color: var(--color-accent); }
    }

    &__add-btn {
      background: var(--color-surface-2);
      border: 1px solid var(--color-border);
      color: var(--color-text);
      border-radius: 0 var(--radius) var(--radius) 0;
      padding: 0.22rem 0.6rem;
      font-size: 0.73rem;
      cursor: pointer;
      white-space: nowrap;
      transition: border-color 0.1s, color 0.1s;

      &:hover { border-color: var(--color-accent); color: var(--color-accent); }
      &.added { border-color: var(--color-success); color: var(--color-success); cursor: default; }
      &.error { border-color: var(--color-danger); color: var(--color-danger); cursor: default; }
      &:disabled { opacity: 0.5; cursor: not-allowed; }
    }
  }
</style>

<script>
  let debounceTimer: ReturnType<typeof setTimeout>;

  const input = document.getElementById('search-input') as HTMLInputElement;
  const results = document.getElementById('search-results') as HTMLDivElement;

  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    const q = input.value.trim();
    if (q.length < 2) { results.hidden = true; return; }
    debounceTimer = setTimeout(() => doSearch(q), 500);
  });

  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('#pack-search')) {
      results.hidden = true;
    }
  });

  async function doSearch(q: string) {
    const res = await fetch(`/api/search?q=${encodeURIComponent(q)}`);
    if (!res.ok) return;
    const items: any[] = await res.json();

    results.innerHTML = '';

    if (items.length === 0) {
      results.innerHTML = '<div class="search__empty">No products found</div>';
      results.hidden = false;
      return;
    }

    // Group by set name, preserving order of first appearance
    const setMap = new Map<string, { packs: any[], year: string }>();
    for (const product of items) {
      if (!setMap.has(product.setName)) {
        setMap.set(product.setName, { packs: [], year: product.releasedAt?.slice(0, 4) ?? '' });
      }
      setMap.get(product.setName)!.packs.push(product);
    }

    for (const [setName, { packs, year }] of setMap) {
      const group = document.createElement('div');
      group.className = 'set-group';
      group.innerHTML = `
        <div class="set-group__header">
          <span class="set-group__name">${setName}</span>
          ${year ? `<span class="set-group__year">${year}</span>` : ''}
        </div>
      `;

      for (const product of packs) {
        const price = product.marketPrice != null ? `$${product.marketPrice.toFixed(2)}` : '';
        const packRow = document.createElement('div');
        packRow.className = 'set-group__pack';
        packRow.innerHTML = `
          <span class="set-group__type">${product.productType}</span>
          ${price ? `<span class="set-group__price">${price}</span>` : ''}
          <div class="set-result__add-group">
            <input class="set-result__qty" type="number" value="1" min="1" max="999" title="Quantity" />
            <button class="set-result__add-btn"
              data-id="${product.mtgstocksId}"
              data-name="${product.name}"
              data-set-name="${product.setName}"
              data-product-type="${product.productType}"
              data-price="${product.marketPrice ?? ''}">
              + Add
            </button>
          </div>
        `;
        group.appendChild(packRow);
      }

      results.appendChild(group);
    }

    results.hidden = false;

    results.querySelectorAll<HTMLButtonElement>('.set-result__add-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        btn.disabled = true;

        const qtyInput = btn.closest('.set-result__add-group')?.querySelector<HTMLInputElement>('.set-result__qty');
        const quantity = parseInt(qtyInput?.value ?? '1') || 1;
        const marketPrice = btn.dataset.price ? parseFloat(btn.dataset.price) : null;

        const res = await fetch('/api/collection', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            mtgstocksId: parseInt(btn.dataset.id!),
            name: btn.dataset.name,
            setName: btn.dataset.setName,
            productType: btn.dataset.productType,
            quantity,
            weight: 1.0,
            marketPrice,
          }),
        });

        if (res.ok) {
          btn.textContent = '✓ Added';
          btn.classList.add('added');
          document.dispatchEvent(new CustomEvent('collection-updated'));
        } else {
          btn.textContent = 'Error';
          btn.classList.add('error');
          btn.disabled = false;
        }
      });
    });
  }
</script>

---
import Layout from '../layouts/Layout.astro';
import PackSelector from '../components/PackSelector.astro';

const apiUrl = import.meta.env.API_URL ?? 'http://api:8080';
const cookie = Astro.request.headers.get('cookie') ?? '';

let meRes: Response;
try {
  meRes = await fetch(`${apiUrl}/api/auth/me`, { headers: { cookie } });
} catch {
  return Astro.redirect('/login');
}
if (!meRes.ok) return Astro.redirect('/login');
const user = await meRes.json();

const collRes = await fetch(`${apiUrl}/api/collection`, { headers: { cookie } });
const allPacks = collRes.ok ? await collRes.json() : [];
const packs = allPacks.filter((p: any) => p.quantity > 0);
---

<Layout title="Pick a Pack" user={user}>
  <div class="page">
    <h1 class="page__title">Pick a Pack</h1>
    <p class="page__sub">Select the packs you want in the pool.</p>
    <PackSelector packs={packs} />
  </div>
</Layout>

<style lang="scss">
  .page {
    &__title {
      font-size: 1.6rem;
      margin-bottom: 0.4rem;
    }

    &__sub {
      color: var(--color-text-muted);
      margin-bottom: 1.5rem;
    }
  }
</style>

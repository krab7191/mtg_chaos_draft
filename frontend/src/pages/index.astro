---
const apiUrl = import.meta.env.API_URL ?? 'http://api:8080';
let meRes: Response;
try {
  meRes = await fetch(`${apiUrl}/api/auth/me`, {
    headers: { cookie: Astro.request.headers.get('cookie') ?? '' },
  });
} catch {
  return Astro.redirect('/login');
}

if (!meRes.ok) return Astro.redirect('/login');

return Astro.redirect(['admin', 'viewer'].includes((await meRes.json()).role) ? '/admin/collection' : '/select');
---

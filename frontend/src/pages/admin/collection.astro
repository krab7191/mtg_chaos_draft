---
import Layout from '../../layouts/Layout.astro';
import PackSearch from '../../components/PackSearch.astro';

const apiUrl = import.meta.env.API_URL ?? 'http://api:8080';
const cookie = Astro.request.headers.get('cookie') ?? '';

let meRes: Response;
try {
  meRes = await fetch(`${apiUrl}/api/auth/me`, { headers: { cookie } });
} catch {
  return Astro.redirect('/login');
}
if (!meRes.ok) return Astro.redirect('/login');
const user = await meRes.json();
const ADMIN_ROLES = ['admin', 'viewer'];
if (!ADMIN_ROLES.includes(user.role)) return Astro.redirect('/select');

const colRes = await fetch(`${apiUrl}/api/collection`, { headers: { cookie } });
const packs = colRes.ok ? await colRes.json() : [];

// Group by set, preserving server sort (empty packs last within each set)
const setMap = new Map<string, any[]>();
for (const pack of packs) {
  if (!setMap.has(pack.setName)) setMap.set(pack.setName, []);
  setMap.get(pack.setName)!.push(pack);
}
for (const [, group] of setMap) {
  group.sort((a: any, b: any) => (a.quantity === 0 ? 1 : 0) - (b.quantity === 0 ? 1 : 0));
}
const sets = Array.from(setMap.entries());

const totalValue: number = packs.reduce((sum: number, p: any) =>
  sum + (p.marketPrice ?? 0) * p.quantity, 0);
---

<Layout title="Manage Collection" user={user}>
  <div class="page">
    <h1 class="page__title">Manage Collection</h1>
    <p class="page__sub">Search to add packs, or remove ones you no longer have.</p>

    <PackSearch />

    <section class="collection">
      <div class="collection__header">
        <h2 class="collection__heading">In your collection</h2>
        {totalValue > 0 && (
          <span class="collection__value">
            Total: <strong id="collection-total">${totalValue.toFixed(2)}</strong>
          </span>
        )}
      </div>

      <p class="collection__disclaimer">Prices update automatically once a day.</p>

      <p class="collection__empty" id="collection-empty" style={packs.length > 0 ? 'display:none' : ''}>
        Nothing yet — search above to add some packs.
      </p>

      <div class="pack-list" id="collection-list" style={packs.length === 0 ? 'display:none' : ''}>
        {sets.map(([setName, setPacks]) => (
          <div class="set-group">
            <div class="set-group__header">
              <span class="set-group__name">{setName}</span>
            </div>
            {setPacks.map((pack: any, i: number) => (
              <div
                class:list={['pack-row', { 'row--empty': pack.quantity === 0 }]}
                data-id={pack.id}
                data-price={pack.marketPrice ?? 0}
                data-order={i}
              >
                <span class="pack-row__type col-set">{pack.productType}</span>
                <div class="qty" data-id={pack.id}>
                  <button class="qty__btn qty__btn--dec" data-id={pack.id}>−</button>
                  <span class="qty__val">{pack.quantity}</span>
                  <button class="qty__btn qty__btn--inc" data-id={pack.id}>+</button>
                </div>
                <span class="price-val" data-id={pack.id}>
                  {pack.marketPrice != null ? `$${pack.marketPrice.toFixed(2)}` : '—'}
                </span>
                <button class="btn-delete" data-id={pack.id} title="Remove">✕</button>
              </div>
            ))}
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>

<style lang="scss">
  .page {
    &__title { font-size: 1.4rem; margin-bottom: 0.3rem; }
    &__sub   { color: var(--color-text-muted); margin-bottom: 1.5rem; font-size: 0.9rem; }
  }

  .collection {
    &__header {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      margin-bottom: 0.75rem;
    }

    &__heading {
      font-size: 1rem;
      font-weight: 600;
      color: var(--color-text-muted);
      margin-bottom: 0;
    }

    &__value {
      font-size: 0.85rem;
      color: var(--color-text-muted);
      strong { color: var(--color-text); font-variant-numeric: tabular-nums; }
    }

    &__disclaimer {
      font-size: 0.78rem;
      color: var(--color-text-muted);
      opacity: 0.6;
      margin-bottom: 0.75rem;
    }

    &__empty {
      color: var(--color-text-muted);
      padding: 2rem 0;
      text-align: center;
      font-size: 0.9rem;
    }
  }

  /* ── Set groups ──────────────────────────────────────────── */
  .pack-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .set-group {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;

    &__header {
      padding: 0.45rem 0.75rem;
      background: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
    }

    &__name {
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--color-text-muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
  }

  /* ── Pack rows ───────────────────────────────────────────── */
  .pack-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--color-border);

    &:last-child { border-bottom: none; }
    &:hover { background: var(--color-surface); }
    &.row--empty { opacity: 0.4; }

    &__type {
      flex: 1;
      min-width: 0;
      font-size: 0.9rem;
      font-weight: 500;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
  }

  .price-val {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
    width: 4.5rem;
    text-align: right;
    flex-shrink: 0;
  }

  /* ── Qty widget ──────────────────────────────────────────── */
  .qty {
    display: flex;
    align-items: center;
    gap: 0.35rem;

    &__val {
      min-width: 1.5rem;
      text-align: center;
      font-variant-numeric: tabular-nums;
      font-size: 0.9rem;
    }

    &__btn {
      background: none;
      border: 1px solid var(--color-border);
      color: var(--color-text-muted);
      border-radius: var(--radius);
      width: 1.6rem;
      height: 1.6rem;
      font-size: 1rem;
      line-height: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;

      &:hover { border-color: var(--color-accent); color: var(--color-accent); }
      &:disabled { opacity: 0.3; cursor: not-allowed; }
    }
  }

  .btn-delete {
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    border-radius: var(--radius);
    padding: 0.2rem 0.45rem;
    font-size: 0.78rem;
    flex-shrink: 0;
    &:hover { border-color: var(--color-danger); color: var(--color-danger); }
  }
</style>

<script>
  function reorderRows() {
    document.querySelectorAll<HTMLElement>('.set-group').forEach(group => {
      const rows = Array.from(group.querySelectorAll<HTMLElement>('.pack-row'));
      rows.sort((a, b) => {
        const aEmpty = a.classList.contains('row--empty') ? 1 : 0;
        const bEmpty = b.classList.contains('row--empty') ? 1 : 0;
        if (aEmpty !== bEmpty) return aEmpty - bEmpty;
        return parseInt(a.dataset.order!) - parseInt(b.dataset.order!);
      });
      rows.forEach(row => group.appendChild(row));
    });
  }

  function recalcTotal() {
    const totalEl = document.getElementById('collection-total');
    if (!totalEl) return;
    let sum = 0;
    document.querySelectorAll<HTMLElement>('.pack-row[data-price]').forEach((row) => {
      const price = parseFloat(row.dataset.price ?? '0');
      const qty   = parseInt(row.querySelector<HTMLElement>('.qty__val')?.textContent ?? '0');
      sum += price * qty;
    });
    totalEl.textContent = `$${sum.toFixed(2)}`;
  }

  // +/- qty buttons
  document.querySelectorAll<HTMLElement>('.qty').forEach((widget) => {
    const id      = widget.dataset.id!;
    const valEl   = widget.querySelector<HTMLElement>('.qty__val')!;
    const decBtn  = widget.querySelector<HTMLButtonElement>('.qty__btn--dec')!;
    const incBtn  = widget.querySelector<HTMLButtonElement>('.qty__btn--inc')!;

    const update = async (delta: number) => {
      const current = parseInt(valEl.textContent ?? '1');
      const next    = Math.max(0, current + delta);
      valEl.textContent = String(next);
      decBtn.disabled   = next === 0;
      widget.closest('.pack-row')?.classList.toggle('row--empty', next === 0);
      reorderRows();
      recalcTotal();
      await fetch(`/api/collection/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ quantity: next }),
      });
    };

    decBtn.disabled = parseInt(valEl.textContent ?? '1') === 0;
    decBtn.addEventListener('click', () => update(-1));
    incBtn.addEventListener('click', () => update(+1));
  });

  // Delete
  document.querySelectorAll<HTMLButtonElement>('.btn-delete').forEach((btn) => {
    btn.addEventListener('click', () => {
      const row = btn.closest<HTMLElement>('.pack-row')!;
      const label = row.querySelector('.col-set')?.textContent ?? 'Pack';
      row.style.opacity = '0.3';
      row.style.pointerEvents = 'none';
      window.deleteToast(
        `Remove "${label}"?`,
        async () => {
          await fetch(`/api/collection/${btn.dataset.id}`, { method: 'DELETE' });
          const group = row.closest<HTMLElement>('.set-group')!;
          row.remove();
          recalcTotal();
          if (group.querySelectorAll('.pack-row').length === 0) {
            group.remove();
          }
          if (document.getElementById('collection-list')?.querySelectorAll('.pack-row').length === 0) {
            document.getElementById('collection-list')!.style.display = 'none';
            document.getElementById('collection-empty')!.style.display = '';
          }
        },
        () => {
          row.style.opacity = '';
          row.style.pointerEvents = '';
        },
      );
    });
  });

  // Reload when PackSearch adds something
  document.addEventListener('collection-updated', () => window.location.reload());
</script>

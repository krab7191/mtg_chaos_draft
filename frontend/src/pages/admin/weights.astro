---
import Layout from '../../layouts/Layout.astro';

const apiUrl = import.meta.env.API_URL ?? 'http://api:8080';
const cookie = Astro.request.headers.get('cookie') ?? '';

const meRes = await fetch(`${apiUrl}/api/auth/me`, { headers: { cookie } });
if (!meRes.ok) return Astro.redirect('/login');
const user = await meRes.json();
const ADMIN_ROLES = ['admin', 'viewer'];
if (!ADMIN_ROLES.includes(user.role)) return Astro.redirect('/select');

const colRes = await fetch(`${apiUrl}/api/collection`, { headers: { cookie } });
const packs = colRes.ok ? await colRes.json() : [];
---

<Layout title="Weights" user={user}>
  <div class="page">
    <h1 class="page__title">Weights</h1>

    <!-- ── Pack table ─────────────────────────────────────────── -->
    {packs.length === 0 ? (
      <p class="page__empty">No packs yet — <a href="/admin/collection">add some first</a>.</p>
    ) : (
      <div class="table-scroll">
        <table class="table" id="weights-table">
          <thead>
            <tr>
              <th>Set</th>
              <th>Type</th>
              <th>Qty</th>
              <th>Price</th>
              <th>Odds</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {packs.map((pack: any) => (
              <tr
                data-id={pack.id}
                data-price={pack.marketPrice ?? ''}
                data-qty={pack.quantity}
              >
                <td class="col-set">{pack.setName}</td>
                <td class="col-type">{pack.productType}</td>
                <td class="col-num">{pack.quantity}</td>
                <td class="col-num col-price-val">
                  {pack.marketPrice != null ? `$${pack.marketPrice.toFixed(2)}` : '—'}
                </td>
                <td class="col-odds">
                  <div class="odds">
                    <div class="odds__bar"><div class="odds__fill" style="width:0%"></div></div>
                    <span class="odds__label">—</span>
                  </div>
                </td>
                <td class="col-actions">
                  <button class="btn-delete" data-id={pack.id} title="Remove">✕</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</Layout>

<style lang="scss">
  .page {
    &__title { font-size: 1.4rem; margin-bottom: 1rem; }
    &__empty { color: var(--color-text-muted); padding: 3rem 0; text-align: center; }
  }

  /* ── Table ───────────────────────────────────────────────── */
  .table-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .table {
    width: 100%;
    min-width: 520px;
    border-collapse: collapse;
    font-size: 0.9rem;

    th {
      text-align: left;
      padding: 0.6rem 0.75rem;
      color: var(--color-text-muted);
      font-weight: 600;
      border-bottom: 2px solid var(--color-border);
      white-space: nowrap;
    }

    td {
      padding: 0.55rem 0.75rem;
      border-bottom: 1px solid var(--color-border);
      vertical-align: middle;
    }

    tr:hover td { background: var(--color-surface); }

    .col-set       { font-weight: 500; white-space: nowrap; }
    .col-type      { color: var(--color-text-muted); font-size: 0.85rem; white-space: nowrap; }
    .col-num       { width: 6rem; }
    .col-price-val { color: var(--color-text-muted); font-variant-numeric: tabular-nums; font-size: 0.88rem; }
    .col-odds      { min-width: 10rem; }
  }

  .odds {
    display: flex;
    align-items: center;
    gap: 0.5rem;

    &__bar {
      flex: 1;
      height: 6px;
      background: var(--color-border);
      border-radius: 3px;
      overflow: hidden;
    }

    &__fill {
      height: 100%;
      background: var(--color-accent);
      border-radius: 3px;
      transition: width 0.25s ease;
    }

    &__label {
      font-size: 0.8rem;
      color: var(--color-text-muted);
      min-width: 3rem;
      text-align: right;
      font-variant-numeric: tabular-nums;
    }
  }

  .btn-delete {
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    border-radius: var(--radius);
    padding: 0.2rem 0.45rem;
    font-size: 0.78rem;
    &:hover { border-color: var(--color-danger); color: var(--color-danger); }
  }
</style>

<script>
  function recalcOdds() {
    const table = document.getElementById('weights-table') as HTMLElement;
    const rows  = Array.from(table.querySelectorAll<HTMLTableRowElement>('tbody tr'));

    const prices = rows
      .map(r => r.dataset.price ? parseFloat(r.dataset.price) : null)
      .filter((p): p is number => p !== null && p > 0);
    const avgPrice = prices.length ? prices.reduce((a, b) => a + b, 0) / prices.length : 1;

    const pw = rows.map(r => {
      const price = r.dataset.price ? parseFloat(r.dataset.price) : null;
      return 1 / ((price && price > 0) ? price : avgPrice);
    });
    const sw = rows.map(r => {
      const qty = parseInt(r.dataset.qty ?? '0');
      return qty > 0 ? 1 / qty : 0;
    });

    const priceTotal    = pw.reduce((a, b) => a + b, 0);
    const scarcityTotal = sw.reduce((a, b) => a + b, 0);

    const weights = rows.map((_, i) => {
      if (sw[i] === 0) return 0;
      const priceOdds    = priceTotal    > 0 ? pw[i] / priceTotal    : 0;
      const scarcityOdds = scarcityTotal > 0 ? sw[i] / scarcityTotal : 0;
      return Math.min(priceOdds, scarcityOdds);
    });

    const total = weights.reduce((a, b) => a + b, 0);
    rows.forEach((row, i) => {
      const pct = total > 0 ? (weights[i] / total) * 100 : 0;
      row.querySelector<HTMLElement>('.odds__fill')!.style.width  = `${pct}%`;
      row.querySelector<HTMLElement>('.odds__label')!.textContent = `${pct.toFixed(1)}%`;
    });
  }

  document.querySelectorAll<HTMLButtonElement>('.btn-delete').forEach((btn) => {
    btn.addEventListener('click', () => {
      const row = btn.closest<HTMLElement>('tr')!;
      const label = row.querySelector('.col-set')?.textContent ?? 'Pack';
      row.style.opacity = '0.3';
      row.style.pointerEvents = 'none';
      window.deleteToast(
        `Remove "${label}"?`,
        async () => {
          await fetch(`/api/collection/${btn.dataset.id}`, { method: 'DELETE' });
          row.remove();
          recalcOdds();
        },
        () => {
          row.style.opacity = '';
          row.style.pointerEvents = '';
        },
      );
    });
  });

  recalcOdds();
</script>

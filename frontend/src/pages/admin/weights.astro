---
import Layout from '../../layouts/Layout.astro';

const apiUrl = import.meta.env.API_URL ?? 'http://api:8080';
const cookie = Astro.request.headers.get('cookie') ?? '';

let meRes: Response;
try {
  meRes = await fetch(`${apiUrl}/api/auth/me`, { headers: { cookie } });
} catch {
  return Astro.redirect('/login');
}
if (!meRes.ok) return Astro.redirect('/login');
const user = await meRes.json();
const ADMIN_ROLES = ['admin', 'viewer'];
if (!ADMIN_ROLES.includes(user.role)) return Astro.redirect('/select');

const [colRes, settingsRes] = await Promise.all([
  fetch(`${apiUrl}/api/collection`, { headers: { cookie } }),
  fetch(`${apiUrl}/api/settings`, { headers: { cookie } }),
]);
const packs: any[] = colRes.ok ? await colRes.json() : [];
const settings = settingsRes.ok ? await settingsRes.json() : { priceCap: 0, priceFloor: 0, quantityCap: 0, packWeights: {} };

const setMap = new Map<string, any[]>();
for (const pack of packs) {
  if (!setMap.has(pack.setName)) setMap.set(pack.setName, []);
  setMap.get(pack.setName)!.push(pack);
}
const sets = Array.from(setMap.entries());
---

<Layout title="Weights" user={user}>
  <div class="page">
    <h1 class="page__title">Weights</h1>

    <!-- ── Global caps ────────────────────────────────────────── -->
    <div class="caps">
      <div class="caps__field">
        <label class="caps__label" for="price-floor">Price floor</label>
        <div class="caps__input-wrap">
          <span class="caps__prefix">$</span>
          <input id="price-floor" class="caps__input" type="number" min="0" step="1"
            placeholder="None" value={settings.priceFloor > 0 ? settings.priceFloor : ''} />
        </div>
        <span class="caps__hint">Cheap packs treated as this price</span>
      </div>
      <div class="caps__field">
        <label class="caps__label" for="price-cap">Price cap</label>
        <div class="caps__input-wrap">
          <span class="caps__prefix">$</span>
          <input id="price-cap" class="caps__input" type="number" min="0" step="1"
            placeholder="None" value={settings.priceCap > 0 ? settings.priceCap : ''} />
        </div>
        <span class="caps__hint">Expensive packs treated as this price</span>
      </div>
      <div class="caps__field">
        <label class="caps__label" for="qty-cap">Pack qty cap</label>
        <input id="qty-cap" class="caps__input" type="number" min="0" step="1"
          placeholder="None" value={settings.quantityCap > 0 ? settings.quantityCap : ''} />
        <span class="caps__hint">High-qty packs treated as this qty</span>
      </div>
      <button class="btn-save" id="save-caps">Save</button>
    </div>

    <!-- ── Pack list ──────────────────────────────────────────── -->
    {packs.length === 0 ? (
      <p class="page__empty">No packs yet — <a href="/admin/collection">add some first</a>.</p>
    ) : (
      <>
      <div class="pack-sort">
        <span class="pack-sort__label">Sort:</span>
        <button class="sort-btn sort-btn--active" id="sort-name">Set ↑</button>
        <button class="sort-btn" id="sort-price">Price</button>
        <button class="sort-btn" id="sort-weight">Weight</button>
      </div>
      <div class="pack-list" id="pack-list">
        {sets.map(([setName, setPacks]) => (
          <div class="set-group">
            <div class="set-group__header">
              <span class="set-group__name">{setName}</span>
            </div>
            {setPacks.map((pack: any) => (
              <div
                class="pack-row"
                data-id={pack.id}
                data-price={pack.marketPrice ?? ''}
                data-qty={pack.quantity}
              >
                <div class="pack-row__type">{pack.productType}</div>
                <div class="pack-row__stats">
                  <span class="pack-row__qty">{pack.quantity} packs</span>
                  <span class="pack-row__price">
                    {pack.marketPrice != null ? `$${pack.marketPrice.toFixed(2)}` : '—'}
                  </span>
                  <div class="odds">
                    <div class="odds__bar"><div class="odds__fill" style="width:0%"></div></div>
                    <span class="odds__label">—</span>
                  </div>
                  <label class="mult-label">
                    ×<input
                      class="mult-input"
                      type="number"
                      min="0"
                      step="0.1"
                      value={(settings.packWeights?.[pack.id] ?? 1).toFixed(1)}
                      data-id={pack.id}
                    />
                  </label>
                </div>
              </div>
            ))}
          </div>
        ))}
      </div>
      </>
    )}
  </div>
</Layout>

<style lang="scss">
  .page {
    &__title { font-size: 1.4rem; margin-bottom: 1rem; }
    &__empty { color: var(--color-text-muted); padding: 3rem 0; text-align: center; }
  }

  /* ── Caps ────────────────────────────────────────────────── */
  .caps {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 0.75rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.9rem 1.1rem;
    margin-bottom: 1.25rem;

    &__field {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }

    &__label {
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--color-text-muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    &__input-wrap {
      position: relative;
      display: flex;
      align-items: center;
    }

    &__prefix {
      position: absolute;
      left: 0.55rem;
      color: var(--color-text-muted);
      font-size: 0.88rem;
      pointer-events: none;
    }

    &__input {
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      color: var(--color-text);
      font-size: 0.88rem;
      padding: 0.35rem 0.55rem;
      width: 7rem;
      &:focus { outline: none; border-color: var(--color-accent); }
    }

    .caps__input-wrap &__input { padding-left: 1.3rem; }

    &__hint {
      font-size: 0.72rem;
      color: var(--color-text-muted);
      opacity: 0.7;
    }
  }

  .btn-save {
    background: var(--color-accent);
    color: #fff;
    border: none;
    border-radius: var(--radius);
    padding: 0.4rem 1rem;
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    align-self: flex-end;
    &:hover { opacity: 0.85; }
    &:disabled { opacity: 0.5; cursor: default; }
  }

  /* ── Sort bar ────────────────────────────────────────────── */
  .pack-sort {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.75rem;

    &__label {
      font-size: 0.78rem;
      color: var(--color-text-muted);
      margin-right: 0.2rem;
    }
  }

  .sort-btn {
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-text-muted);
    font-size: 0.78rem;
    padding: 0.2rem 0.55rem;
    cursor: pointer;
    transition: border-color 0.1s, color 0.1s;

    &:hover { border-color: var(--color-accent); color: var(--color-text); }
    &--active { border-color: var(--color-accent); color: var(--color-accent); }
  }

  /* ── Set groups ──────────────────────────────────────────── */
  .pack-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .set-group {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;

    &__header {
      padding: 0.45rem 0.75rem;
      background: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
    }

    &__name {
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--color-text);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
  }

  /* ── Pack rows ───────────────────────────────────────────── */
  .pack-row {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--color-border);

    &:last-child { border-bottom: none; }

    &__type {
      font-size: 0.9rem;
      font-weight: 400;
      color: var(--color-text-muted);
      margin-bottom: 0.2rem;
    }

    &__stats {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    &__qty {
      font-size: 0.78rem;
      color: var(--color-text-muted);
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
    }

    &__price {
      font-size: 0.78rem;
      color: var(--color-text-muted);
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
    }
  }

  /* ── Odds ────────────────────────────────────────────────── */
  .odds {
    display: flex;
    align-items: center;
    gap: 0.4rem;

    &__bar {
      width: 60px;
      flex-shrink: 0;
      height: 5px;
      background: var(--color-border);
      border-radius: 3px;
      overflow: hidden;
    }

    &__fill {
      height: 100%;
      background: var(--color-accent);
      border-radius: 3px;
      transition: width 0.25s ease;
    }

    &__label {
      font-size: 0.78rem;
      color: var(--color-text-muted);
      width: 3rem;
      text-align: right;
      font-variant-numeric: tabular-nums;
      flex-shrink: 0;
    }
  }

  /* ── Per-pack multiplier ─────────────────────────────────── */
  .mult-label {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-weight: 500;
    flex-shrink: 0;
  }

  .mult-input {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-text);
    font-size: 0.85rem;
    padding: 0.15rem 0.35rem;
    width: 3.5rem;
    text-align: right;
    &:focus { outline: none; border-color: var(--color-accent); }
  }
</style>

<script>
  const priceFloorInput = document.getElementById('price-floor') as HTMLInputElement;
  const priceCapInput   = document.getElementById('price-cap')   as HTMLInputElement;
  const qtyCapInput     = document.getElementById('qty-cap')     as HTMLInputElement;
  const saveBtn         = document.getElementById('save-caps')   as HTMLButtonElement;

  const num    = (el: HTMLInputElement) => { const v = parseFloat(el.value); return isNaN(v) || v <= 0 ? 0 : v; };
  const numInt = (el: HTMLInputElement) => { const v = parseInt(el.value);   return isNaN(v) || v <= 0 ? 0 : v; };

  function getPackWeights(): Record<string, number> {
    const result: Record<string, number> = {};
    document.querySelectorAll<HTMLInputElement>('.mult-input').forEach(input => {
      const v = parseFloat(input.value);
      result[input.dataset.id!] = isNaN(v) || v < 0 ? 1 : v;
    });
    return result;
  }

  function recalcOdds() {
    const rows = Array.from(document.querySelectorAll<HTMLElement>('.pack-row'));
    if (!rows.length) return;

    const priceFloor = num(priceFloorInput);
    const priceCap   = num(priceCapInput);
    const qtyCap     = numInt(qtyCapInput);
    const packWeights = getPackWeights();

    const capPrice = (p: number) => {
      if (priceFloor > 0 && p < priceFloor) p = priceFloor;
      if (priceCap   > 0 && p > priceCap)   p = priceCap;
      return p;
    };
    const capQty = (q: number) => qtyCap > 0 && q > qtyCap ? qtyCap : q;

    const rawPrices = rows.map(r => {
      const p = r.dataset.price ? parseFloat(r.dataset.price) : null;
      return p && p > 0 ? capPrice(p) : null;
    });
    const validPrices = rawPrices.filter((p): p is number => p !== null);
    const avgPrice = validPrices.length ? validPrices.reduce((a, b) => a + b, 0) / validPrices.length : 1;

    const pw = rows.map((_, i) => 1 / (rawPrices[i] ?? avgPrice));
    const sw = rows.map(r => { const q = capQty(parseInt(r.dataset.qty ?? '0')); return q > 0 ? 1 / q : 0; });

    const priceTotal    = pw.reduce((a, b) => a + b, 0);
    const scarcityTotal = sw.reduce((a, b) => a + b, 0);

    const weights = rows.map((r, i) => {
      if (sw[i] === 0) return 0;
      const base = Math.min(
        priceTotal    > 0 ? pw[i] / priceTotal    : 0,
        scarcityTotal > 0 ? sw[i] / scarcityTotal : 0,
      );
      const mult = packWeights[r.dataset.id!] ?? 1;
      return base * (mult > 0 ? mult : 0);
    });

    const total = weights.reduce((a, b) => a + b, 0);
    rows.forEach((row, i) => {
      const pct = total > 0 ? (weights[i] / total) * 100 : 0;
      row.querySelector<HTMLElement>('.odds__fill')!.style.width  = `${pct}%`;
      row.querySelector<HTMLElement>('.odds__label')!.textContent = `${pct.toFixed(1)}%`;
    });

    if (sortKey === 'weight') applySort();
  }

  // ── Sort ──────────────────────────────────────────────────
  let sortKey: 'name' | 'price' | 'weight' = 'name';
  let sortDir: 'asc' | 'desc' = 'asc';

  const sortNameBtn   = document.getElementById('sort-name')   as HTMLButtonElement;
  const sortPriceBtn  = document.getElementById('sort-price')  as HTMLButtonElement;
  const sortWeightBtn = document.getElementById('sort-weight') as HTMLButtonElement;
  const packList      = document.getElementById('pack-list');

  const rowPrice  = (r: HTMLElement) => { const p = parseFloat(r.dataset.price ?? ''); return isNaN(p) ? Infinity : p; };
  const rowWeight = (r: HTMLElement) => parseFloat(r.querySelector<HTMLElement>('.odds__label')?.textContent ?? '0') || 0;

  function applySort() {
    if (!packList) return;
    const groups = Array.from(packList.querySelectorAll<HTMLElement>('.set-group'));

    groups.sort((a, b) => {
      if (sortKey === 'name') {
        const an = a.querySelector('.set-group__name')?.textContent ?? '';
        const bn = b.querySelector('.set-group__name')?.textContent ?? '';
        return sortDir === 'asc' ? an.localeCompare(bn) : bn.localeCompare(an);
      }
      const val = (g: HTMLElement) => {
        const rows = Array.from(g.querySelectorAll<HTMLElement>('.pack-row'));
        if (sortKey === 'price') {
          const prices = rows.map(rowPrice).filter(p => p !== Infinity);
          return prices.length ? Math.min(...prices) : Infinity;
        }
        return Math.max(...rows.map(rowWeight));
      };
      const diff = val(a) - val(b);
      return sortDir === 'asc' ? diff : -diff;
    });

    if (sortKey !== 'name') {
      groups.forEach(group => {
        const rows = Array.from(group.querySelectorAll<HTMLElement>('.pack-row'));
        rows.sort((a, b) => {
          const av = sortKey === 'price' ? rowPrice(a) : rowWeight(a);
          const bv = sortKey === 'price' ? rowPrice(b) : rowWeight(b);
          return sortDir === 'asc' ? av - bv : bv - av;
        });
        rows.forEach(r => group.appendChild(r));
      });
    }

    groups.forEach(g => packList.appendChild(g));

    sortNameBtn.classList.toggle('sort-btn--active', sortKey === 'name');
    sortPriceBtn.classList.toggle('sort-btn--active', sortKey === 'price');
    sortWeightBtn.classList.toggle('sort-btn--active', sortKey === 'weight');
    const arrow = sortDir === 'asc' ? ' ↑' : ' ↓';
    sortNameBtn.textContent   = 'Set'    + (sortKey === 'name'   ? arrow : '');
    sortPriceBtn.textContent  = 'Price'  + (sortKey === 'price'  ? arrow : '');
    sortWeightBtn.textContent = 'Weight' + (sortKey === 'weight' ? arrow : '');
  }

  function onSortClick(key: typeof sortKey) {
    if (sortKey === key) sortDir = sortDir === 'asc' ? 'desc' : 'asc';
    else { sortKey = key; sortDir = key === 'name' ? 'asc' : 'desc'; }
    applySort();
  }

  sortNameBtn?.addEventListener('click',   () => onSortClick('name'));
  sortPriceBtn?.addEventListener('click',  () => onSortClick('price'));
  sortWeightBtn?.addEventListener('click', () => onSortClick('weight'));

  priceFloorInput.addEventListener('input', recalcOdds);
  priceCapInput.addEventListener('input', recalcOdds);
  qtyCapInput.addEventListener('input', recalcOdds);
  document.querySelectorAll<HTMLInputElement>('.mult-input').forEach(el =>
    el.addEventListener('input', recalcOdds)
  );

  saveBtn.addEventListener('click', async () => {
    saveBtn.disabled = true;
    await fetch('/api/settings', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        priceFloor:   num(priceFloorInput),
        priceCap:     num(priceCapInput),
        quantityCap:  numInt(qtyCapInput),
        packWeights:  getPackWeights(),
      }),
    });
    saveBtn.disabled = false;
  });

  recalcOdds();
  applySort();
</script>

{
  "name": "mtg-chaos-draft-frontend",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check && svelte-check --tsconfig ./tsconfig.svelte-check.json",
    "test": "vitest run --coverage && node -e \"const s=JSON.parse(require('fs').readFileSync('./coverage/coverage-summary.json','utf8'));console.log('Coverage: '+s.total.statements.pct+'%')\""
  },
  "engines": {
    "node": ">=24.13.1"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/node": "^9.5.4",
    "@astrojs/svelte": "^7.2.5",
    "astro": "^5.17.3",
    "sass": "^1.97.3",
    "svelte": "^5.53.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "svelte-check": "^4.4.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
